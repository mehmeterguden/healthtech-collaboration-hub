generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                    String           @id @default(cuid())
  slug                  String           @unique
  email                 String           @unique
  password              String
  firstName             String
  lastName              String
  role                  String           @default("engineer")
  institution           String           @default("")
  city                  String           @default("")
  country               String           @default("")
  expertise             String           @default("[]")
  bio                   String           @default("")
  avatarUrl             String           @default("")
  profileCompleteness   Int              @default(40)
  isActive              Boolean          @default(true)
  isEmailVerified       Boolean          @default(false)
  emailVerificationCode String?
  profileViews          Int              @default(0)
  lastLogin             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  auditLogs             AuditLog[]
  interests             Interest[]
  messages              Message[]
  receivedRequests      MeetingRequest[] @relation("ReceivedRequests")
  sentRequests          MeetingRequest[] @relation("SentRequests")
  notifications         Notification[]
  partneredPosts        Post[]           @relation("SelectedPartner")
  posts                 Post[]
}

model Post {
  id                   String           @id @default(cuid())
  authorId             String
  title                String
  domain               String
  description          String
  requiredExpertise    String           @default("[]")
  projectStage         String           @default("idea")
  commitmentLevel      String           @default("medium")
  collaborationType    String           @default("research_partner")
  confidentialityLevel String           @default("public")
  highLevelIdea        String?
  city                 String           @default("")
  country              String           @default("")
  status               String           @default("active")
  expiryDate           DateTime?
  autoClose            Boolean          @default(false)
  interestCount        Int              @default(0)
  selectedPartnerId    String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  interests            Interest[]
  meetingRequests      MeetingRequest[]
  selectedPartner      User?            @relation("SelectedPartner", fields: [selectedPartnerId], references: [id])
  author               User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Interest {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model MeetingRequest {
  id            String   @id @default(cuid())
  postId        String
  requesterId   String
  receiverId    String
  message       String   @default("")
  proposedSlots String   @default("[]")
  selectedSlot  String?
  status        String   @default("pending")
  ndaAccepted   Boolean  @default(false)
  meetingLink   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      Message[]
  receiver      User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  requester     User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  linkTo    String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  userName     String   @default("Unknown")
  userRole     String   @default("")
  actionType   String
  targetEntity String
  targetId     String   @default("")
  resultStatus String   @default("success")
  details      String?
  ipAddress    String?
  timestamp    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  meetingId  String
  senderId   String
  content    String
  createdAt  DateTime @default(now())
  meeting    MeetingRequest @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
